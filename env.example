# ProxyPoolMaster 环境变量模板
# 复制为 .env 后按需修改

# ===============================
# 必填（生产环境务必修改）
# ===============================
API_TOKEN=change_me_to_a_strong_token
# 仅在 legacy 模式或启用内置站大爷收集器时需要；Collector V2 默认不需要
ZDAYE_APP_ID=your_app_id_here
ZDAYE_AKEY=your_akey_here

# ===============================
# Redis
# ===============================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ===============================
# 日志（日志文件路径固定为 /app/logs/app.log）
# ===============================
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
TIMEZONE=Asia/Shanghai

# ===============================
# 收集器
# ===============================
REQUEST_TIMEOUT=10
COLLECT_INTERVAL_SECONDS=300
ZDAYE_COLLECT_INTERVAL=300
ZDAYE_OVERSEAS_COLLECT_INTERVAL=300
# COLLECTORS=[{"id":"zdaye","name":"站大爷免费代理","enabled":true,"interval_seconds":300}]

# ===============================
# 测试器
# ===============================
TEST_INTERVAL_SECONDS=300
MAX_FAIL_COUNT=5
TESTER_LOG_EACH_PROXY=false
TEST_MAX_CONCURRENT=100
TEST_TIMEOUT_PER_TARGET=5
TEST_BATCH_SIZE=200
TEST_IDLE_SLEEP_SECONDS=2
TEST_SCHEDULE_ZSET_KEY=proxies:test_schedule
TEST_MIGRATION_BATCH_SIZE=500

# ===============================
# API 限流（slowapi: 次数/单位）
# ===============================
RATE_LIMIT_PROXY_MINUTE=60/minute
RATE_LIMIT_HEALTH_MINUTE=30/minute

# ===============================
# API 服务运行参数（可选）
# ===============================
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_WS_BROADCAST_INTERVAL_SECONDS=10
SYSTEM_WS_BROADCAST_INTERVAL_SECONDS=10
DISABLE_API_TESTER=0

# ===============================
# Collector 运行模式
# legacy: 仅启动旧版 CollectorManager
# v2: 启用 Collector V2 运行时，并自动启用 V2 UI / 自动迁移
# disabled: 不启动任何 collector 调度
# ===============================
COLLECTOR_RUNTIME_MODE=v2

# ===============================
# Collector Worker
# ===============================
COLLECTOR_WORKER_ENABLED=1
COLLECTOR_WORKER_ID=collector-worker-1
COLLECTOR_WORKER_TICK_SECONDS=1
COLLECTOR_WORKER_MAX_CONCURRENT=4

# ===============================
# 构建 / 发布元信息（可选）
# 左下角版本号优先展示 APP_IMAGE_TAG；若为空则回退到构建期版本号与 Git SHA
# GitHub Actions 自动构建时可由 workflow 注入，无需手工填写
# ===============================
# APP_RELEASE_VERSION=
# APP_GIT_SHA=
# APP_IMAGE_TAG=

# ===============================
# Collector 执行隔离
# ===============================
COLLECTOR_EXEC_TIMEOUT=60
COLLECTOR_EXEC_MAX_MEMORY_MB=256
COLLECTOR_EXEC_STDOUT_LIMIT_KB=256
COLLECTOR_RUN_HISTORY_LIMIT=200
